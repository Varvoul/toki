###
# App
###
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:PYtYpRrZ3s9znzelPxnM2UyUxG76+ZWzcgvOXGZEZ0I=
APP_TIMEZONE=UTC
APP_URL=https://toki.onrender.com
APP_VERSION="4.2.2"

###
# Logging
###
LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=
LOG_LEVEL=warning

###
# Database Caching (MongoDB)
###
DB_CACHING=true
DB_CONNECTION=mongodb
# For MongoDB Atlas, use DB_DSN (full connection string with replica set)
# For local dev, use DB_HOST/DB_PORT/DB_USERNAME/DB_PASSWORD/DB_ADMIN
DB_DSN=mongodb://foogyfogg_db_user:lOGjbIkcVouYZwAK@ac-dk2blxh-shard-00-00.0vgvu1v.mongodb.net:27017,ac-dk2blxh-shard-00-01.0vgvu1v.mongodb.net:27017,ac-dk2blxh-shard-00-02.0vgvu1v.mongodb.net:27017/?replicaSet=atlas-30bzxr-shard-0&authSource=admin&appName=toki-v4
DB_HOST=localhost
DB_PORT=27017
DB_DATABASE=jikan
DB_ADMIN=jikan
DB_USERNAME=
DB_PASSWORD=

###
# Database query default values
###
MAX_RESULTS_PER_PAGE=25

###
# Enable MyAnimeList Heartbeat
###
SOURCE=local
SOURCE_BAD_HEALTH_THRESHOLD=10
SOURCE_BAD_HEALTH_RECHECK=10
SOURCE_BAD_HEALTH_RANGE=30
SOURCE_BAD_HEALTH_MAX_STORE=50
SOURCE_GOOD_HEALTH_SCORE=0.9
SOURCE_TIMEOUT=30

###
# Caching Configuration
# DB_CACHING handles MongoDB-based request caching (main cache mechanism)
# CACHING=false and CACHE_DRIVER=array means no additional Redis/file cache layer
###
CACHING=false
CACHE_DRIVER=array

# Cache TTL: 72 hours = 259200 seconds (as requested for Toki)
CACHE_DEFAULT_EXPIRE=259200
CACHE_META_EXPIRE=300
CACHE_USER_EXPIRE=259200
CACHE_USERLIST_EXPIRE=259200
CACHE_404_EXPIRE=259200
CACHE_SEARCH_EXPIRE=259200
CACHE_PRODUCERS_EXPIRE=259200
CACHE_MAGAZINES_EXPIRE=259200
CACHE_MICROCACHE_EXPIRE=5

###
# Redis Caching Configuration (not used on Render free tier)
###
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

###
# Micro Caching
###
MICROCACHING=false
MICROCACHING_EXPIRE=5

###
# Queue management (uses MongoDB as queue backend)
###
QUEUE_CONNECTION=database
QUEUE_TABLE=jobs
QUEUE_FAILED_TABLE=jobs_failed
QUEUE_DELAY_PER_JOB=5
JIKAN_QUEUE_WORKER_PROCESS_NUM=0

###
# Scout config (MongoDB regex search - no Typesense/Elasticsearch needed)
###
SCOUT_DRIVER=none
SCOUT_QUEUE=false

###
# GitHub generate report URL on fatal errors
###
GITHUB_REPORTING=false

###
# OpenAPI
###
SWAGGER_VERSION=3.0

###
# API call insights
###
INSIGHTS=false
INSIGHTS_MAX_STORE_TIME=172800

###
# Error reporting
###
REPORTING=false

###
# CORS (enable for browser access)
###
CORS_MIDDLEWARE=true

###
# User lists
###
DISABLE_USER_LISTS=false